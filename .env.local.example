# VaultGate — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real credentials.

# ─── Auth0 Token Vault (Required for Production) ────────────────────────────
# Get these from your Auth0 dashboard → Applications → Machine to Machine

AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_client_id_here
AUTH0_CLIENT_SECRET=your_client_secret_here

# Token Vault API audience (usually https://auth0.com/ai/)
AUTH0_TOKEN_VAULT_API=https://auth0.com/ai/

# Auth0 connection ID for CIBA (Token Vault → Connections → Slack)
AUTH0_TOKEN_VAULT_CONNECTION_ID=conn_slack_your_id_here

# ─── CIBA Configuration ─────────────────────────────────────────────────────
# User ID or email to pre-fill in CIBA login_hint
# (e.g., auth0|user123 or user@example.com)
CIBA_LOGIN_HINT=your-user-id-or-email@example.com

# Demo mode override: set to 'true' to force demo mode even with credentials
# VAULTGATE_DEMO_MODE=true

# ─── Slack ──────────────────────────────────────────────────────────────────
# Bot token from Slack OAuth — starts with xoxb-
# Required for real Slack API calls
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# ─── Server Configuration ───────────────────────────────────────────────────
VAULTGATE_PORT=18792
VAULTGATE_HOST=localhost

# Suppress startup banner (useful for demo scripts)
# VAULTGATE_QUIET=1

# ─── Demo Mode Configuration ───────────────────────────────────────────────
# Number of poll cycles before auto-approval in demo mode (default: 3)
# Lower = faster demo (e.g., 1 for instant approval)
# Higher = slower (e.g., 10 to show more poll iterations)
# DEMO_APPROVAL_DELAY_POLLS=3
