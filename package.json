{
  "name": "vaultgate",
  "version": "1.0.0",
  "description": "Secure gateway agent for Auth0 Token Vault — CIBA-powered human-in-the-loop auth for AI agents",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node --loader ts-node/esm src/index.ts",
    "cli": "node --loader ts-node/esm cli/index.ts",
    "dev": "tsx src/index.ts",
    "cli:dev": "tsx cli/index.ts",
    "try": "bash demo-try.sh",
    "try:ci": "bash demo-ci.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run"
  },
  "keywords": [
    "auth0",
    "token-vault",
    "ciba",
    "ai-agents",
    "security"
  ],
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.37",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsd": "^0.33.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
