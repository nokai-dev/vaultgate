{
  "name": "vaultgate",
  "version": "1.0.0",
  "description": "Secure gateway agent for Auth0 Token Vault — CIBA-powered human-in-the-loop auth for AI agents",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node --loader ts-node/esm src/index.ts",
    "cli": "node --loader ts-node/esm cli/index.ts",
    "dev": "tsx src/index.ts",
    "cli:dev": "tsx cli/index.ts"
  },
  "keywords": ["auth0", "token-vault", "ciba", "ai-agents", "security"],
  "license": "MIT",
  "dependencies": {
    "@auth0/auth0-ai": "^1.0.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
